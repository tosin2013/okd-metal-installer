---
extends: default

rules:
  line-length:
    max: 200
    level: warning
  truthy:
    allowed-values: ["true", "false", "yes", "no"]
    check-keys: false
  indentation:
    spaces: 2
    indent-sequences: consistent
  comments:
    min-spaces-from-content: 1
  comments-indentation: false
  braces:
    max-spaces-inside: 1
  brackets:
    max-spaces-inside: 1
  document-start:
    present: true
  empty-lines:
    max: 2
  octal-values:
    forbid-implicit-octal: true
    forbid-explicit-octal: true

ignore:
  - .cache/
  - "*.j2"
