apiVersion: v1
metadata:
  name: {{ cluster_name }}
baseDomain: {{ base_domain }}
controlPlane:
  name: master
  replicas: {{ groups['masters'] | length }}
  platform: {}
compute:
  - name: worker
    replicas: {{ groups['workers'] | default([]) | length }}
    platform: {}
networking:
  networkType: {{ network_type }}
  clusterNetwork:
    - cidr: {{ cluster_network_cidr }}
      hostPrefix: {{ cluster_network_host_prefix }}
  serviceNetwork:
    - {{ service_network_cidr }}
{% if cluster_topology == 'compact' %}
  machineNetwork:
    - cidr: {{ machine_network_cidr | default('10.0.0.0/16') }}
{% endif %}
platform:
  none: {}
pullSecret: '{{ lookup("file", pull_secret_path) }}'
sshKey: '{{ lookup("file", ssh_key_path) }}'
{% if cluster_topology == 'sno' %}
bootstrapInPlace:
  installationDisk: {{ installation_disk | default(dest_device | default('/dev/sda')) }}
{% endif %}
{% if cluster_topology == 'compact' %}
schedulable: true
{% endif %}
{% if image_content_sources | length > 0 %}
imageContentSources:
{% for source in image_content_sources %}
  - mirrors:
{% for mirror in source.mirrors %}
      - {{ mirror }}
{% endfor %}
    source: {{ source.source }}
{% endfor %}
{% endif %}
{% if additional_trust_bundle_path | length > 0 %}
additionalTrustBundle: |
{{ lookup("file", additional_trust_bundle_path) | indent(2, first=True) }}
{% endif %}
