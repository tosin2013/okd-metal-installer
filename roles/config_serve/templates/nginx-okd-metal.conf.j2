server {
    listen {{ config_serve_port }};
    server_name _;

    root {{ config_serve_root }};
    autoindex on;

    # Ignition configs
    location /ignition/ {
        types {
            application/vnd.coreos.ignition+json ign;
        }
        default_type application/vnd.coreos.ignition+json;
    }

    # ISO images
    location /iso/ {
        types {
            application/octet-stream iso;
        }
        default_type application/octet-stream;
    }

    # Discovery agent phone-home endpoint placeholder
    # A real listener can be added later; for now return 200
    location /api/v1/discovery {
        default_type application/json;
        return 200 '{"status": "acknowledged"}';
    }

    # Health check
    location /healthz {
        default_type text/plain;
        return 200 'ok';
    }
}
