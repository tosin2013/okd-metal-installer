# OKD-Metal internal DNS configuration
# Generated by roles/dns_internal for disconnected environments

# Listen on jumpbox interface
listen-address={{ dns_internal_listen_address }},127.0.0.1
bind-interfaces

{% if dns_internal_upstream | length > 0 %}
# Upstream DNS (empty for fully air-gapped)
server={{ dns_internal_upstream }}
{% endif %}

# Do not use /etc/resolv.conf
no-resolv

# Do not read /etc/hosts
no-hosts

# Cluster: {{ cluster_name }}.{{ base_domain }}

{% set master_ips = groups['masters'] | default([]) | map('extract', hostvars, 'ansible_host') | list %}
{% set worker_ips = groups['workers'] | default([]) | map('extract', hostvars, 'ansible_host') | list %}

{% if api_vip | length > 0 %}
# API VIP
address=/api.{{ cluster_name }}.{{ base_domain }}/{{ api_vip }}
address=/api-int.{{ cluster_name }}.{{ base_domain }}/{{ api_vip }}
{% else %}
# API -> all master IPs (round-robin)
{% for ip in master_ips %}
address=/api.{{ cluster_name }}.{{ base_domain }}/{{ ip }}
address=/api-int.{{ cluster_name }}.{{ base_domain }}/{{ ip }}
{% endfor %}
{% endif %}

{% if ingress_vip | length > 0 %}
# Ingress VIP
address=/.apps.{{ cluster_name }}.{{ base_domain }}/{{ ingress_vip }}
{% elif worker_ips | length > 0 %}
# Ingress -> worker IPs
{% for ip in worker_ips %}
address=/.apps.{{ cluster_name }}.{{ base_domain }}/{{ ip }}
{% endfor %}
{% else %}
# Ingress -> master IPs (compact/SNO)
{% for ip in master_ips %}
address=/.apps.{{ cluster_name }}.{{ base_domain }}/{{ ip }}
{% endfor %}
{% endif %}

# Per-node A records
{% for host in groups['masters'] | default([]) %}
address=/{{ host }}.{{ cluster_name }}.{{ base_domain }}/{{ hostvars[host].ansible_host }}
{% endfor %}
{% for host in groups['workers'] | default([]) %}
address=/{{ host }}.{{ cluster_name }}.{{ base_domain }}/{{ hostvars[host].ansible_host }}
{% endfor %}
